# Copy this file to .env and fill in values for production / postgres setup.
# DO NOT COMMIT your real .env with secrets to version control.

# Django secret key
SECRET-KEY=your-secret-key

# Debug flag: True or False
DEBUG=False

# Allowed hosts (comma separated)
ALLOWED-HOSTS=localhost,127.0.0.1

# PostgreSQL settings
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=127.0.0.1
DB_PORT=5432
